# ──────────────────────────────────────────────────────────────────────────
# Required for the OTP email flow (signup + login)
# ──────────────────────────────────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
# If unset, the /api/otp/request endpoint logs the code to the server
# console instead of sending an email (useful for local dev).
RESEND_API_KEY=

# The "From" header on the OTP email.
# Resend requires this to be a verified-domain address in production.
# Defaults to "GoogolPlex <onboarding@resend.dev>" if unset (Resend's
# shared sandbox sender, which only delivers to the account owner's email).
RESEND_FROM=GoogolPlex <hello@yourdomain.com>

# Random secret used to HMAC-sign the OTP cookie + hash the 6-digit code.
# Generate with: openssl rand -hex 32
# DO NOT commit a real secret to git. Set this in Vercel project env vars.
OTP_SECRET=
